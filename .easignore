# Root .easignore - Blacklist mode
node_modules/
.git/
.idea/
.vscode/

# Ignore sibling projects/folders
backend/
deploy/
css/
js/
temp_build/
assets/
index.html
manifest.json
*.md

# Keep mobile/ (do not ignore it)
# But ignore generated stuff inside mobile
mobile/node_modules/
mobile/.expo/
mobile/dist/
mobile/web-build/
