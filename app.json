{
  "expo": {
    "name": "Vocal Walls Mobile",
    "slug": "audio-geo-notes-mobile-v2",
    "version": "2.0.0",
    "icon": "./assets/icon.png",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1017"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "io.vocalwalls.mobile",
      "versionCode": 9,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD3Ffb65r372dKtoYbMxATspYX9IJAECkE"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0f1017"
      },
      "permissions": [
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "io.vocalwalls.mobile",
      "buildNumber": "6",
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app uses the microphone to record audio notes.",
        "NSLocationWhenInUseUsageDescription": "This app uses your location to place audio notes on the map.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "extra": {
      "apiBaseUrlDefault": "http://31.97.77.6:4000",
      "eas": {
        "projectId": "9a234ea3-f79f-49e9-a264-c137c7f484aa"
      }
    },
    "plugins": [
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "usesCleartextTraffic": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "owner": "nix177"
  }
}
